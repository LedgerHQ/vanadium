# Generated by Cargo
# will have compiled files and executables
debug/
target/

# The top-level workspace builds the cargo-vnd binary, so its Cargo.lock is
# tracked. Per-app/per-library lockfiles below it remain ignored.
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock
!/Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# It's convenient to use a virtual environment for speculos,
# so we ignore these folders if present.
venv
.venv

# Used when debugging the V-App clients
**/debug.log
**/print.log

# Produced in integration tests with speculos
**/test.log
